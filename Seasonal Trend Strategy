  Seasonal Trend Strategy (Multi-Month)
  Logic: If the current month matches ANY of the target months, enter long if price is above moving average, short if below.
  Exit when the current month is no longer in the target list.
}


// Warning! This strategy does not include risk management.

Inputs:
    Month1(1),           { first target month (1=January, ..., 12=December) }
    Month2(0),           { second target month (0 = not used) }
    Month3(0),           { third target month (0 = not used) }
    Month4(0),           { fourth target month (0 = not used) }
    MALength(20),        
    size(1);             

Variables:
    MA(0),
    CurrentMonth(0),
    IsTargetMonth(False);

MA = Average(Close, MALength);

{ Current month }
CurrentMonth = Month(Date);

{ Check if current month matches any target month }
IsTargetMonth = False;

If Month1 > 0 And CurrentMonth = Month1 Then IsTargetMonth = True;
If Month2 > 0 And CurrentMonth = Month2 Then IsTargetMonth = True;
If Month3 > 0 And CurrentMonth = Month3 Then IsTargetMonth = True;
If Month4 > 0 And CurrentMonth = Month4 Then IsTargetMonth = True;


If IsTargetMonth And MarketPosition = 0 Then Begin
    If Close > MA Then
        Buy size contract next bar at market;
    If Close < MA Then
        SellShort size contract next bar at market;
End;


If Not IsTargetMonth And MarketPosition <> 0 Then Begin
    If MarketPosition = 1 Then
        Sell size contract next bar at market;
    If MarketPosition = -1 Then
        BuyToCover size contract next bar at market;
End;


